{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node16"
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "scripts/**/*"
  ]
}